# Enterprise Knowledge Brain — 环境变量模板
# 复制为 .env 并填入真实值:
#   cp .env.example .env

# ── 运行模式 ────────────────────────────────────────────────────────────────
# demo: 允许本地 mock SQL/API 适配器；production: 强制使用真实外部适配器
APP_PROFILE=demo
LOG_LEVEL=INFO

# ── LLM: DeepSeek V3 ─────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ── Neo4j 图数据库 ────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── Milvus 向量数据库 ─────────────────────────────────────────────────────────
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=enterprise_docs

# ── Embedding 模型（本地推理，首次下载约 2.3GB）──────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
# HuggingFace 镜像（访问受限时使用）:
# HF_ENDPOINT=https://hf-mirror.com

# ── 建库参数 ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=100
LLM_BATCH_SIZE=5
LLM_TEMPERATURE=0.1
LLM_MAX_RETRIES=2

# ── Agent / 检索参数 ──────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
GRAPH_HOP_DEPTH=2
AGENT_TEMPERATURE=0.1
SYNTHESIS_TEMPERATURE=0.3

# ── 监控与评估 (LangSmith Tracing) ─────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=EnterpriseKnowledgeBrain

# ── HTTP/API 网关 ────────────────────────────────────────────────────────────
# 逗号分隔，production 模式禁止使用 *
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8000
# 可选：查询审计事件 HTTP webhook。为空时 demo profile 仅记录日志。
QUERY_AUDIT_WEBHOOK_URL=

# ── MCP 服务地址 ─────────────────────────────────────────────────────────────
MCP_API_SERVER_URL=http://localhost:8001/mcp
MCP_SQL_SERVER_URL=http://localhost:8002/mcp
MCP_GRAPHRAG_SERVER_URL=http://localhost:8003/mcp
MCP_DATA_ANALYSIS_SERVER_URL=http://localhost:8004/mcp
MCP_WEB_SEARCH_SERVER_URL=http://localhost:8005/mcp

# ── Redis / checkpoint / cache ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── 真实业务适配器（production 必填）─────────────────────────────────────────
BUSINESS_SQL_DATABASE_URL=
INTERNAL_API_BASE_URL=
INTERNAL_API_TIMEOUT_SECONDS=10

# ── DataAnalysis Worker 本地代码模型 ─────────────────────────────────────────
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL_NAME=Qwen/Qwen2.5-Coder-32B-Instruct
